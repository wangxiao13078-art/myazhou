/* quiz.wxss - 专题集训页样式 */

.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #10B981 0%, #f5f5f5 300rpx);
  padding-bottom: 120rpx;
}

/* 头部 */
.header {
  padding: 48rpx 32rpx;
  color: #fff;
}

.header-title {
  font-size: 48rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 8rpx;
}

.header-subtitle {
  font-size: 28rpx;
  opacity: 0.9;
}

/* 集训列表 */
.quiz-list {
  padding: 0 30rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.quiz-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx 24rpx;
  border-left: 8rpx solid #10B981;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.quiz-left {
  display: flex;
  align-items: center;
  flex: 1;
}

.quiz-icon {
  font-size: 48rpx;
  margin-right: 20rpx;
}

.quiz-info {
  display: flex;
  flex-direction: column;
}

.quiz-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.quiz-count {
  font-size: 24rpx;
  color: #888;
  margin-top: 4rpx;
}

.quiz-right {
  display: flex;
  align-items: center;
}

.quiz-start {
  font-size: 26rpx;
  color: #10B981;
  font-weight: 500;
}

/* 区块 */
.section {
  padding: 30rpx;
  margin-top: 16rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #1a1a1a;
  margin-bottom: 20rpx;
}

/* 期末冲刺 */
.final-quiz {
  background: linear-gradient(135deg, #F59E0B 0%, #D97706 100%);
  border-radius: 20rpx;
  padding: 36rpx 32rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  color: #fff;
  box-shadow: 0 8rpx 24rpx rgba(245, 158, 11, 0.3);
}

.final-left {
  display: flex;
  align-items: center;
}

.final-icon {
  font-size: 64rpx;
  margin-right: 20rpx;
}

.final-info {
  display: flex;
  flex-direction: column;
}

.final-name {
  font-size: 36rpx;
  font-weight: bold;
}

.final-desc {
  font-size: 24rpx;
  opacity: 0.9;
  margin-top: 4rpx;
}

.final-arrow {
  font-size: 28rpx;
  background: rgba(255, 255, 255, 0.2);
  padding: 12rpx 24rpx;
  border-radius: 24rpx;
}

/* 弹窗遮罩 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 100;
}

/* 弹窗内容 */
.modal-content {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  z-index: 101;
  transform: translateY(100%);
  transition: transform 0.3s ease;
  max-height: 80vh;
  display: flex;
  flex-direction: column;
}

.modal-content.show {
  transform: translateY(0);
}

.modal-header {
  padding: 32rpx;
  display: flex;
  align-items: center;
  border-radius: 32rpx 32rpx 0 0;
  color: #fff;
}

.modal-icon {
  font-size: 48rpx;
  margin-right: 16rpx;
}

.modal-title {
  font-size: 36rpx;
  font-weight: bold;
  flex: 1;
}

.modal-close {
  font-size: 48rpx;
  opacity: 0.8;
  padding: 0 16rpx;
}

.modal-body {
  flex: 1;
  overflow-y: auto;
  padding-bottom: env(safe-area-inset-bottom);
}

/* 题目列表 */
.problem-list {
  padding: 20rpx;
}

.problem-item {
  display: flex;
  align-items: center;
  padding: 24rpx 20rpx;
  background: #f8fafc;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
}

.problem-index {
  width: 56rpx;
  height: 56rpx;
  background: linear-gradient(135deg, #3B82F6 0%, #2563EB 100%);
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: bold;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.problem-info {
  flex: 1;
  overflow: hidden;
}

.problem-title {
  font-size: 28rpx;
  color: #333;
  display: block;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.problem-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 8rpx;
}

.problem-tag {
  font-size: 20rpx;
  color: #666;
  background: #e5e7eb;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.problem-difficulty {
  display: flex;
  margin-left: 16rpx;
}

.star {
  font-size: 20rpx;
  color: #ddd;
}

.star.filled {
  color: #F59E0B;
}

/* 题目箭头 */
.problem-arrow {
  font-size: 32rpx;
  color: #999;
  margin-left: 16rpx;
}
