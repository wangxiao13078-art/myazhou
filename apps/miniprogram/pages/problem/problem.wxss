/* problem.wxss - 题目详情页样式（仿PWA版） */

.container {
  min-height: 100vh;
  background: #f5f7fa;
  padding: 24rpx;
  padding-bottom: 180rpx;
}

/* 顶部行 */
.header-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.tags-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tag {
  background: linear-gradient(135deg, #dbeafe 0%, #bfdbfe 100%);
  color: #1d4ed8;
  padding: 8rpx 16rpx;
  border-radius: 16rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.difficulty-row {
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.difficulty-label {
  font-size: 22rpx;
  color: #f59e0b;
  margin-right: 8rpx;
}

.star {
  font-size: 20rpx;
  color: #e5e7eb;
}

.star.filled {
  color: #f59e0b;
}

/* 标题 */
.title-section {
  margin-bottom: 20rpx;
}

.problem-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #1f2937;
  line-height: 1.4;
}

/* 分隔线 */
.divider {
  height: 2rpx;
  background: linear-gradient(90deg, transparent, #e5e7eb, transparent);
  margin: 20rpx 0;
}

/* 内容卡片 */
.content-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  border: 1rpx solid #e5e7eb;
}

.content-text {
  font-size: 32rpx;
  line-height: 1.9;
  color: #374151;
  white-space: pre-wrap;
  word-wrap: break-word;
}

/* 图形卡片 */
.svg-card {
  background: linear-gradient(135deg, #eff6ff 0%, #dbeafe 100%);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  border: 2rpx solid #93c5fd;
}

.card-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.card-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.card-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #1d4ed8;
}

.svg-container {
  display: flex;
  justify-content: center;
  background: #fff;
  border-radius: 12rpx;
  padding: 20rpx;
}

.svg-image {
  width: 100%;
  max-width: 600rpx;
  height: 300rpx;
}

/* 方法点拨卡片 */
.method-card {
  background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  border-left: 8rpx solid #f59e0b;
}

.method-header {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.method-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.method-label {
  font-size: 26rpx;
  font-weight: bold;
  color: #92400e;
}

.method-name {
  font-size: 30rpx;
  color: #78350f;
  font-weight: 500;
}

/* 分步解析区域 */
.steps-section {
  margin-top: 32rpx;
}

.section-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-line {
  flex: 1;
  height: 2rpx;
  background: #d1d5db;
}

.section-title {
  padding: 0 20rpx;
  font-size: 26rpx;
  color: #6b7280;
  font-weight: bold;
}

/* 步骤列表 */
.steps-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.step-item {
  background: #fff;
  border-radius: 12rpx;
  overflow: hidden;
  border: 2rpx solid #e5e7eb;
  transition: all 0.3s;
}

.step-item.expanded {
  border-color: #3b82f6;
  box-shadow: 0 4rpx 16rpx rgba(59, 130, 246, 0.15);
}

.step-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  background: #f9fafb;
}

.step-item.expanded .step-header {
  background: #eff6ff;
}

.step-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #374151;
  flex: 1;
}

.step-item.expanded .step-title {
  color: #1d4ed8;
}

.step-arrow {
  font-size: 24rpx;
  color: #9ca3af;
}

.step-item.expanded .step-arrow {
  color: #3b82f6;
}

.step-body {
  padding: 24rpx;
  border-top: 1rpx solid #e5e7eb;
}

.step-content {
  font-size: 30rpx;
  line-height: 1.8;
  color: #4b5563;
  white-space: pre-wrap;
  word-wrap: break-word;
}

.step-formula {
  margin-top: 16rpx;
  background: linear-gradient(135deg, #ecfdf5 0%, #d1fae5 100%);
  padding: 16rpx 20rpx;
  border-radius: 8rpx;
  border-left: 4rpx solid #10b981;
}

.formula-text {
  font-size: 30rpx;
  color: #065f46;
  font-family: serif;
}

/* 针对训练区域 */
.training-section {
  margin-top: 32rpx;
}

.training-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.training-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.training-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #1f2937;
}

.training-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.training-item {
  display: flex;
  align-items: center;
  background: #fff;
  padding: 20rpx 24rpx;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.03);
  border: 1rpx solid #e5e7eb;
}

.training-index {
  width: 48rpx;
  height: 48rpx;
  background: linear-gradient(135deg, #10b981 0%, #059669 100%);
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: bold;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.training-name {
  flex: 1;
  font-size: 28rpx;
  color: #374151;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.training-arrow {
  font-size: 32rpx;
  color: #9ca3af;
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  display: flex;
  gap: 20rpx;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.06);
  border-top: 1rpx solid #e5e7eb;
}

.btn-back {
  flex: 1;
  background: #fff;
  color: #3b82f6;
  border: 2rpx solid #3b82f6;
  border-radius: 48rpx;
  padding: 20rpx;
  font-size: 30rpx;
  font-weight: 500;
}

.btn-next {
  flex: 1;
  background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
  color: #fff;
  border: none;
  border-radius: 48rpx;
  padding: 20rpx;
  font-size: 30rpx;
  font-weight: 500;
}

.btn-back::after, .btn-next::after {
  border: none;
}

/* 加载中 */
.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 100vh;
}

.loading-text {
  color: #9ca3af;
  font-size: 28rpx;
}
