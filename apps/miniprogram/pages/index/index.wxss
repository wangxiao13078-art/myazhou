/* index.wxss - 首页样式 */

.container {
  padding: 0;
  background: linear-gradient(180deg, #3B82F6 0%, #f5f5f5 300rpx);
  min-height: 100vh;
}

/* 头部横幅 */
.header-banner {
  padding: 40rpx 30rpx;
  color: #fff;
}

.banner-content {
  margin-bottom: 40rpx;
}

.banner-title {
  font-size: 56rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 8rpx;
}

.banner-subtitle {
  font-size: 28rpx;
  opacity: 0.9;
}

.banner-stats {
  display: flex;
  justify-content: space-around;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 16rpx;
  padding: 24rpx 0;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-number {
  font-size: 44rpx;
  font-weight: bold;
}

.stat-label {
  font-size: 24rpx;
  opacity: 0.8;
  margin-top: 4rpx;
}

/* 区块 */
.section {
  padding: 30rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #1a1a1a;
  margin-bottom: 24rpx;
}

/* 专题卡片 */
.chapter-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.chapter-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx;
  border-left: 8rpx solid #3B82F6;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.chapter-header {
  display: flex;
  align-items: center;
  flex: 1;
}

.chapter-icon {
  font-size: 48rpx;
  margin-right: 20rpx;
}

.chapter-info {
  display: flex;
  flex-direction: column;
}

.chapter-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.chapter-desc {
  font-size: 24rpx;
  color: #888;
  margin-top: 4rpx;
}

.chapter-meta {
  display: flex;
  align-items: center;
}

.chapter-count {
  font-size: 24rpx;
  color: #3B82F6;
  background: #EBF5FF;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  margin-right: 12rpx;
}

.chapter-arrow {
  font-size: 36rpx;
  color: #ccc;
}

/* 快速入口 */
.quick-links {
  display: flex;
  gap: 20rpx;
}

.quick-link {
  flex: 1;
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
  position: relative;
}

.final-link {
  background: linear-gradient(135deg, #FEF3C7 0%, #FDE68A 100%);
  border: 2rpx solid #F59E0B;
}

.quick-icon {
  font-size: 56rpx;
  margin-bottom: 12rpx;
}

.quick-text {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
}

.quick-badge {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  background: #EF4444;
  color: #fff;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 16rpx;
}
