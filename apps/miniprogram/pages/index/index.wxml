<!--index.wxml - 首页-->
<view class="container">
  <!-- 头部横幅 -->
  <view class="header-banner">
    <view class="banner-content">
      <text class="banner-title">M压轴</text>
      <text class="banner-subtitle">初中数学压轴题 84个考法全覆盖</text>
    </view>
    <view class="banner-stats">
      <view class="stat-item">
        <text class="stat-number">84</text>
        <text class="stat-label">考法</text>
      </view>
      <view class="stat-item">
        <text class="stat-number">6</text>
        <text class="stat-label">专题</text>
      </view>
      <view class="stat-item">
        <text class="stat-number">200+</text>
        <text class="stat-label">例题</text>
      </view>
    </view>
  </view>

  <!-- 专题列表 -->
  <view class="section">
    <view class="section-title">📚 专题目录</view>
    
    <view class="chapter-list">
      <view 
        class="chapter-card" 
        wx:for="{{chapters}}" 
        wx:key="id"
        bindtap="goToChapter"
        data-id="{{item.id}}"
        style="border-left-color: {{item.color}};"
      >
        <view class="chapter-header">
          <text class="chapter-icon">{{item.icon}}</text>
          <view class="chapter-info">
            <text class="chapter-name">{{item.name}}</text>
            <text class="chapter-desc">{{item.desc}}</text>
          </view>
        </view>
        <view class="chapter-meta">
          <text class="chapter-count">{{item.count}}个考法</text>
          <text class="chapter-arrow">›</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 快速入口 -->
  <view class="section">
    <view class="section-title">🚀 快速入口</view>
    <view class="quick-links">
      <view class="quick-link final-link" bindtap="goToFinalQuiz">
        <text class="quick-icon">🎯</text>
        <text class="quick-text">期末冲刺练</text>
        <text class="quick-badge">16题</text>
      </view>
      <view class="quick-link" bindtap="goToQuiz">
        <text class="quick-icon">💪</text>
        <text class="quick-text">专题集训</text>
      </view>
    </view>
  </view>
</view>
