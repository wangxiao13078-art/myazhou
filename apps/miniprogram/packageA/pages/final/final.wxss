/* final.wxss - 期末冲刺练页面样式 */

.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #F59E0B 0%, #f5f5f5 250rpx);
  padding-bottom: 40rpx;
}

.header {
  padding: 48rpx 32rpx;
  color: #fff;
}

.header-title {
  font-size: 48rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 8rpx;
}

.header-subtitle {
  font-size: 28rpx;
  opacity: 0.9;
}

.problem-list {
  padding: 0 24rpx;
}

.problem-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.problem-number {
  width: 64rpx;
  height: 64rpx;
  background: linear-gradient(135deg, #F59E0B 0%, #D97706 100%);
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: bold;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.problem-content {
  flex: 1;
  overflow: hidden;
}

.problem-title {
  font-size: 30rpx;
  color: #1a1a1a;
  font-weight: 500;
  display: block;
  margin-bottom: 8rpx;
}

.problem-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.tag {
  font-size: 22rpx;
  color: #F59E0B;
  background: #FEF3C7;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.problem-meta {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-left: 16rpx;
}

.difficulty {
  display: flex;
  margin-bottom: 8rpx;
}

.star {
  font-size: 20rpx;
  color: #F59E0B;
}

.arrow {
  font-size: 36rpx;
  color: #ccc;
}

.empty {
  padding: 100rpx 0;
  text-align: center;
}

.empty-text {
  color: #999;
  font-size: 28rpx;
}

